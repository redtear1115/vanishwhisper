rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isParticipant(sessionID) {
      let session = get(/databases/$(database)/documents/ChatSessions/$(sessionID)).data;
      return session.Participant1 == request.auth.uid
             || session.Participant2 == request.auth.uid;
    }

    // Phase 1 — Users: each user owns and writes their own doc; any
    // authenticated user can `get` a single Users doc (to fetch another
    // user's public key during invitation). `list` is intentionally not
    // allowed — UIDs are shared out-of-band, not enumerated.
    match /Users/{uid} {
      allow get: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // Phase 1 — ChatSessions: creator must be Participant1 and the invitee
    // (Participant2) must be a different existing user. Either participant
    // can `read` (covers `get` for opening + `list` for the home page —
    // clients must filter by Participant1 == uid or Participant2 == uid).
    // Either participant can `update`, but only the `UpdatedAt` field —
    // used to bump on each new message so the session list re-sorts by
    // most-recent-activity.
    match /ChatSessions/{sessionId} {
      allow read: if request.auth != null
                  && (resource.data.Participant1 == request.auth.uid
                      || resource.data.Participant2 == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.Participant1 == request.auth.uid
                    && request.resource.data.Participant2 != request.auth.uid
                    && exists(/databases/$(database)/documents/Users/$(request.resource.data.Participant2));
      allow update: if request.auth != null
                    && (resource.data.Participant1 == request.auth.uid
                        || resource.data.Participant2 == request.auth.uid)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['UpdatedAt']);
    }

    // ChatMessages: only session participants can read (per-doc rule applies
    // to list queries — clients must filter by SessionID). Create only by a
    // session participant; the message must be tagged with the sender's own
    // UID. Update covers the vanish lifecycle plus phase 2 sender-unsend and
    // reactions — each branch pins to a single affected key to keep writes
    // narrow:
    //   (a) Phase 1 — recipient first-reads (ReadAt == request.time)
    //   (b) Phase 1 — recipient auto-vanishes after read (DeletedAt;
    //       requires ReadAt already present)
    //   (c) Phase 2 — sender unsends their own message (DeletedAt; no ReadAt
    //       prerequisite — sender can pull the rug at any time)
    //   (d) Phase 2 — either participant toggles a Reactions[emoji] entry.
    //       Plaintext map; not strictly limiting which uid is added/removed
    //       because in a 2-party chat there's no third uid to forge.
    match /ChatMessages/{messageId} {
      allow read: if request.auth != null && isParticipant(resource.data.SessionID);
      allow create: if request.auth != null
                    && request.resource.data.UserID == request.auth.uid
                    && isParticipant(request.resource.data.SessionID);
      allow update: if request.auth != null
                    && isParticipant(resource.data.SessionID)
                    && (
                      // (a) recipient sets ReadAt for the first time
                      (
                        request.auth.uid != resource.data.UserID
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ReadAt'])
                        && request.resource.data.ReadAt == request.time
                      )
                      ||
                      // (b) recipient sets DeletedAt after ReadAt was set
                      (
                        request.auth.uid != resource.data.UserID
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['DeletedAt'])
                        && 'ReadAt' in resource.data
                        && request.resource.data.DeletedAt == request.time
                      )
                      ||
                      // (c) sender unsends their own message
                      (
                        request.auth.uid == resource.data.UserID
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['DeletedAt'])
                        && request.resource.data.DeletedAt == request.time
                      )
                      ||
                      // (d) either participant toggles a reaction
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['Reactions'])
                      )
                    );
    }
  }
}
