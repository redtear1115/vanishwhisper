rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isParticipant(sessionID) {
      let session = get(/databases/$(database)/documents/ChatSessions/$(sessionID)).data;
      return session.Participant1 == request.auth.uid
             || session.Participant2 == request.auth.uid;
    }

    // Used by the post-migration "claim orphan messages" flow. A UserID is
    // "orphan" once its owner is no longer in either participant slot of
    // its session — happens after a Phase 2.17 active hand-off where the
    // old UID is replaced with the new device's UID. The new device, on
    // first sight of those messages, rewrites UserID to its own UID so the
    // chat view's fromMe detection / unsend / auto-vanish rules behave
    // correctly. Before migration this is always false (old UID is still
    // a participant), so attempts to "rewrite UserID" pre-migration get
    // rejected.
    function isOrphanUserID(sessionID, oldUid) {
      let s = get(/databases/$(database)/documents/ChatSessions/$(sessionID)).data;
      return s.Participant1 != oldUid && s.Participant2 != oldUid;
    }

    // Helper used by ChatMessages cascade delete: only the AGREER (the
    // participant who isn't the one who requested deletion) can hard-delete
    // messages, and only while a delete request is pending. This keeps a
    // malicious client from going around the UI to nuke history without
    // the other party's consent.
    function isDeleteAgreerFor(sessionID) {
      let s = get(/databases/$(database)/documents/ChatSessions/$(sessionID)).data;
      return (s.Participant1 == request.auth.uid || s.Participant2 == request.auth.uid)
             && 'DeleteRequestedBy' in s
             && s.DeleteRequestedBy != request.auth.uid;
    }

    // Phase 1 — Users: each user owns and writes their own doc; any
    // authenticated user can `get` a single Users doc (to fetch another
    // user's public key during invitation). `list` is intentionally not
    // allowed — UIDs are shared out-of-band, not enumerated.
    match /Users/{uid} {
      allow get: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
    }

    // ChatSessions: creator must be Participant1 and the invitee
    // (Participant2) must be a different existing user. Either participant
    // can `read` (covers `get` for opening + `list` for the home page —
    // clients must filter by Participant1 == uid or Participant2 == uid).
    // Update covers three shapes:
    //   (a) Phase 1 — bump UpdatedAt only (per-message session re-sort)
    //   (b) Phase 2.8 — request mutual delete: set DeleteRequestedBy +
    //       DeleteRequestedAt to the requester's uid + request.time.
    //       Only allowed when no request is currently pending.
    //   (c) Phase 2.8 — cancel/reject delete: clear DeleteRequestedBy +
    //       DeleteRequestedAt. Either party can fire this — requester
    //       changing their mind = cancel, other party = reject.
    // Delete: requires a pending request AND the deleter is NOT the
    // requester. This is the rule-level enforcement of mutual consent —
    // the requester can never delete on their own; only the other party
    // (by definition consenting at delete time) can carry it out.
    match /ChatSessions/{sessionId} {
      allow read: if request.auth != null
                  && (resource.data.Participant1 == request.auth.uid
                      || resource.data.Participant2 == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.Participant1 == request.auth.uid
                    && request.resource.data.Participant2 != request.auth.uid
                    && exists(/databases/$(database)/documents/Users/$(request.resource.data.Participant2));
      allow update: if request.auth != null
                    && (resource.data.Participant1 == request.auth.uid
                        || resource.data.Participant2 == request.auth.uid)
                    && (
                      // (a) bump UpdatedAt + record sender on new message.
                      // LastMessageBy must equal the requester's uid so a
                      // participant can't impersonate the other as the
                      // last sender (which would mess up the home unread dot
                      // on the other side).
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['UpdatedAt', 'LastMessageBy'])
                        && request.resource.data.LastMessageBy == request.auth.uid
                      )
                      ||
                      // (b) request mutual delete
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['DeleteRequestedBy', 'DeleteRequestedAt', 'UpdatedAt'])
                        && !('DeleteRequestedBy' in resource.data)
                        && request.resource.data.DeleteRequestedBy == request.auth.uid
                        && request.resource.data.DeleteRequestedAt == request.time
                      )
                      ||
                      // (c) cancel/reject delete
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['DeleteRequestedBy', 'DeleteRequestedAt', 'UpdatedAt'])
                        && 'DeleteRequestedBy' in resource.data
                        && !('DeleteRequestedBy' in request.resource.data)
                        && !('DeleteRequestedAt' in request.resource.data)
                      )
                      ||
                      // (d) Phase 2.17 — own-slot migration. Swap own
                      // Participant slot to a new UID and update the
                      // matching WrappedKey to one re-wrapped for the new
                      // UID's RSA public key. The session AES key itself
                      // doesn't change — the OTHER party's WrappedKey stays
                      // valid, so they keep being able to decrypt every
                      // message; only the outer RSA wrap that protects MY
                      // copy of the session key gets reissued. The other
                      // slot is untouched.
                      //
                      // Required keys: Participant{1|2}, WrappedKey{1|2},
                      // UpdatedAt. LastMessageBy is optionally rewritten
                      // ONLY when the current LastMessageBy was me (so the
                      // new device's home unread dot doesn't light up on
                      // sessions where I sent the last pre-migration
                      // message). New UID must exist in Users (else the
                      // session would strand on a non-existent UID) and
                      // must not equal the other current participant
                      // (no degenerate self-chat).
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasAll(['Participant1', 'WrappedKey1', 'UpdatedAt'])
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['Participant1', 'WrappedKey1', 'UpdatedAt', 'LastMessageBy'])
                        && resource.data.Participant1 == request.auth.uid
                        && request.resource.data.Participant1 != request.auth.uid
                        && request.resource.data.Participant1 != resource.data.Participant2
                        && exists(/databases/$(database)/documents/Users/$(request.resource.data.Participant1))
                        && (
                          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['LastMessageBy'])
                          || (
                            'LastMessageBy' in resource.data
                            && resource.data.LastMessageBy == request.auth.uid
                            && request.resource.data.LastMessageBy == request.resource.data.Participant1
                          )
                        )
                      )
                      ||
                      // (d-mirror) Same as (d) but for Participant2.
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasAll(['Participant2', 'WrappedKey2', 'UpdatedAt'])
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['Participant2', 'WrappedKey2', 'UpdatedAt', 'LastMessageBy'])
                        && resource.data.Participant2 == request.auth.uid
                        && request.resource.data.Participant2 != request.auth.uid
                        && request.resource.data.Participant2 != resource.data.Participant1
                        && exists(/databases/$(database)/documents/Users/$(request.resource.data.Participant2))
                        && (
                          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['LastMessageBy'])
                          || (
                            'LastMessageBy' in resource.data
                            && resource.data.LastMessageBy == request.auth.uid
                            && request.resource.data.LastMessageBy == request.resource.data.Participant2
                          )
                        )
                      )
                    );
      allow delete: if request.auth != null
                    && (resource.data.Participant1 == request.auth.uid
                        || resource.data.Participant2 == request.auth.uid)
                    && 'DeleteRequestedBy' in resource.data
                    && resource.data.DeleteRequestedBy != request.auth.uid;
    }

    // ChatMessages: only session participants can read (per-doc rule applies
    // to list queries — clients must filter by SessionID). Create only by a
    // session participant; the message must be tagged with the sender's own
    // UID. Update covers the vanish lifecycle plus phase 2 sender-unsend and
    // reactions — each branch pins to a single affected key to keep writes
    // narrow:
    //   (a) Phase 1 — recipient first-reads (ReadAt == request.time)
    //   (b) Phase 1 — recipient auto-vanishes after read (DeletedAt;
    //       requires ReadAt already present)
    //   (c) Phase 2 — sender unsends their own message (DeletedAt; no ReadAt
    //       prerequisite — sender can pull the rug at any time)
    //   (d) Phase 2 — either participant toggles a Reactions[emoji] entry.
    //       Plaintext map; not strictly limiting which uid is added/removed
    //       because in a 2-party chat there's no third uid to forge.
    match /ChatMessages/{messageId} {
      allow read: if request.auth != null && isParticipant(resource.data.SessionID);
      allow create: if request.auth != null
                    && request.resource.data.UserID == request.auth.uid
                    && isParticipant(request.resource.data.SessionID);
      allow update: if request.auth != null
                    && isParticipant(resource.data.SessionID)
                    && (
                      // (a) recipient sets ReadAt for the first time
                      (
                        request.auth.uid != resource.data.UserID
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ReadAt'])
                        && request.resource.data.ReadAt == request.time
                      )
                      ||
                      // (b) recipient sets DeletedAt after ReadAt was set
                      (
                        request.auth.uid != resource.data.UserID
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['DeletedAt'])
                        && 'ReadAt' in resource.data
                        && request.resource.data.DeletedAt == request.time
                      )
                      ||
                      // (c) sender unsends their own message
                      (
                        request.auth.uid == resource.data.UserID
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['DeletedAt'])
                        && request.resource.data.DeletedAt == request.time
                      )
                      ||
                      // (d) either participant toggles a reaction
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['Reactions'])
                      )
                      ||
                      // (e) Phase 2.17 — claim orphan UserID after a
                      // session migration. Rewrite UserID = my UID for
                      // messages whose current UserID is no longer in
                      // either participant slot of the session (i.e. the
                      // previous owner migrated out). Constrained to a
                      // single-field UserID write where the new value is
                      // my UID; the outer guard already requires me to be
                      // a participant of the session, and isOrphanUserID()
                      // ensures we can only claim "abandoned" messages,
                      // not steal each other's authorship in a live chat.
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['UserID'])
                        && resource.data.UserID != request.auth.uid
                        && request.resource.data.UserID == request.auth.uid
                        && isOrphanUserID(resource.data.SessionID, resource.data.UserID)
                      )
                    );
      // Hard delete only by the AGREER during a pending session deletion
      // request. Cascade-deletes the chat history when the other party
      // confirms tearing down the session.
      allow delete: if request.auth != null
                    && isDeleteAgreerFor(resource.data.SessionID);
    }

    // Phase 2.17 — Migrations: a transient encrypted hand-off channel
    // for active migration. Old device writes one doc per recipient
    // carrying { FromUID, Payload }, where Payload is hybrid encryption
    // (AES-256-GCM ciphertext + RSA-OAEP-wrapped AES key) of the
    // sender's IDB labels JSON, decryptable only with the recipient's
    // RSA private key. New device on first launch reads its own
    // Migrations doc, decrypts, applies to local IDB, deletes.
    //
    // Rules trade-offs: the create rule lets ANY authenticated user
    // write a Migrations doc to ANY existing recipient. We can't
    // express "only the legitimate previous-self of recipientId" in
    // rules — there's no on-server link between the OLD UID and the
    // NEW UID after the session-slot swap (rules see only current
    // state). The encryption already protects payload secrecy, and a
    // forged doc only leaks IDB labels for sessionIds the new device
    // doesn't participate in (so they're never rendered, just inert
    // rows). Acceptable risk for a feature whose blast radius is
    // "stranger could plant cosmetic labels you'll never see".
    match /Migrations/{recipientId} {
      allow get, delete: if request.auth != null && request.auth.uid == recipientId;
      allow create, update: if request.auth != null
                    && request.resource.data.FromUID == request.auth.uid
                    && exists(/databases/$(database)/documents/Users/$(recipientId));
    }
  }
}
