rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Phase 1 — Users: each user owns and writes their own doc; any
    // authenticated user can `get` a single Users doc (to fetch another
    // user's public key during invitation). `list` is intentionally not
    // allowed — UIDs are shared out-of-band, not enumerated.
    match /Users/{uid} {
      allow get: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid == uid;
    }

    // ChatSessions and ChatMessages — rules added when those features land.
  }
}
